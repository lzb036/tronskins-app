	@import "../../../theme.scss";

	.pending-shopment-item {
		width: 750rpx;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		padding: 20rpx;
		position: relative;
		border-bottom: 1rpx solid $app-surface;
	}

	.item-header {
		width: 750rpx;
		display: flex;
		flex-direction: row;
		align-items: center;

		.item-user {
			width: 550rpx;
			display: flex;
			flex-direction: row;
			align-items: center;

			.item-avatar {
				width: 50rpx;
				height: 50rpx;
				border-radius: 50rpx;
				border: 1rpx solid $app-surface;
			}

			.item-nickname {
				font-size: $font-size-sm;
				color: $app-text-thirdly;
				padding: 20rpx 0;
				margin-left: 10rpx;
			}
		}

		.item-statusName {
			width: 160rpx;
			font-size: $font-size-sm;
			color: $app-text-thirdly;
			text-align: right;
		}
	}

	.price-wrap {
		width: 520rpx;
		padding-left: 20rpx;

		.market-name {
			font-size: $font-size-md;
			color: $app-text-primary;
			lines: 1;
			text-overflow: ellipsis;
		}

		.market-price {
			font-size: $font-size-md;
			color: $app-text-price;
			font-weight: bold;
			padding-top: 20rpx;
		}
	}
</style>