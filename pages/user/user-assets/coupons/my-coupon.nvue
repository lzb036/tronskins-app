		.tips {
			font-size: $font-size-md;
			text-align: center;
			color: $app-text-thirdly;
		}
	}

	.go-exchange-wrap {
		width: 750rpx;
		background-color: $app-background;
		position: absolute;
		bottom: 0rpx;
		left: 0;
	}

	.go-exchange {
		width: 710rpx;
		margin: 10rpx 20rpx;
		background: $app-link;
		border: 1rpx solid $app-link;
	}

	.coupon-list {
		width: 750rpx;
		padding: 20rpx;
	}

	.coupon-item {
		width: 710rpx;
		height: 200rpx;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		margin-bottom: 40rpx;
		border: 1rpx solid $app-divider;

		.left {
			width: 430rpx;
			height: 200rpx;
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			padding-left: 30rpx;

			.lable {
				color: $app-text-primary;
				font-size: $font-size-md;
			}

			.type {
				color: $app-text-primary;
				font-size: $font-size-sm;
			}

			.mode {
				color: $app-link;
				font-size: $font-size-sm;
				text-align: center;
				padding: 10rpx 20rpx;
				border: 1rpx solid $app-link;
				border-radius: 5rpx;
				margin: 20rpx 0;
			}
		}

		.right {
			width: 280rpx;
			height: 200rpx;
			display: flex;
			flex-wrap: wrap;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			border-left: 2rpx dashed $app-background;

			.time {
				color: $app-background;
				font-size: $font-size-md;
				margin-bottom: 20rpx;
			}

			.use-btn {
				color: $app-background;
				font-size: $font-size-md;
				text-align: center;
				padding: 10rpx 30rpx;
				border: 1rpx solid $app-background;
				border-radius: 10rpx;
			}
		}
	}
</style>