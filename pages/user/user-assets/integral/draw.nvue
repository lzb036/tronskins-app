		transform-origin: bottom;
		margin-top: -10rpx;
		position: relative;
		z-index: -1;
	}

	.draw-box {
		width: 710rpx;
		background: #fdd95b;
		padding: 20rpx;
		border-radius: 20rpx;
		border-top: 6rpx solid #ffe77c;
		position: relative;
		z-index: 1;
		margin-top: -5rpx;

		.market-name {
			font-size: 32rpx;
			color: #fef8e6;
			text-align: center;
			font-weight: 600;
			margin-top: 10rpx;
		}
	}

	.header {
		width: 680rpx;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		margin-bottom: 20rpx;

		.dot {
			width: 30rpx;
