			padding: 20rpx 0;
			background: #efc630;
			border-radius: 20rpx;
			margin: 0 50rpx;
			border: 1rpx solid #f8dd52;

			.opportunity {
				font-size: $font-size-md;
				font-weight: bold;
				color: #fef8e6;
			}
		}
	}

	.rules-box {
		width: 710rpx;
		background: #1b044c;
		padding: 20rpx;

		.title {
			color: #d7d4e4;
			font-size: 30rpx;
			font-weight: bold;
			margin-bottom: 20rpx;
		}

