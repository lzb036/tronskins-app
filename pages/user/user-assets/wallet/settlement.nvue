		width: 750rpx;
	}

	.notice {
		width: 750rpx;
		color: $app-text-thirdly;
		background: $app-surface-elevated;
		font-size: $font-size-sm;
		padding: 15rpx 20rpx;
	}

	.settlement-item {
		width: 750rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 20rpx;
	}

	.item-header {
		width: 710rpx;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;

		.protection-time {
			font-size: $font-size-sm;
			color: $app-text-thirdly;
		}
	}

	.multiple-right {
		width: 150rpx;
		display: flex;
		flex-direction: row;
		align-items: flex-end;
		justify-content: center;
	}

	.item-info {
		width: 710rpx;
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 10rpx 0;

		.item-details-list {
			width: 560rpx;
			display: flex;
			flex-direction: row;
			overflow: hidden;
		}

		.item {
			margin-right: 10rpx;
		}

		.item-nums {
			font-size: $font-size-sm;
			color: $app-text-thirdly;
			margin-left: 5rpx;
			padding: 10rpx 0;
		}

		.total-cost {
			width: 110rpx;
			font-size: $font-size-md;
			color: $app-text-price;
			text-align: right;
			font-weight: bold;
			padding: 10rpx;
			padding-right: 0;
		}

		.price-wrap {
			width: 525rpx;
			height: 52px;
			display: flex;
			flex-direction: row;
			align-items: flex-start;
			justify-content: center;
			padding: 10rpx 0 0 10rpx;
			position: relative;

			.left {
				width: 350rpx;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
			}

			.right {
				width: 140rpx;
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				justify-content: center;
			}

			.market-name {
				width: 350rpx;
				font-size: $font-size-md;
				color: $app-text-secondary;
				lines: 1;
				text-overflow: ellipsis;
			}

			.market-price {
				font-size: $font-size-md;
				color: $app-text-price;
				font-weight: bold;
				text-align: right;
				padding-top: 20rpx;
				padding-right: 0;
			}

			.wear {
				font-size: $font-size-sm;
				color: $app-text-thirdly;
				padding: 5rpx 0;
			}
		}
	}

	.down-time {
		width: 210rpx;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
	}

	.time {
		@include flex;
		align-items: center;

		&__item {
			color: orange;
			font-size: $font-size-count-time;
		}
	}
</style>