					font-weight: bold;
				}
			}
		}

		.item-wear {
			width: 710rpx;
			display: flex;
			flex-direction: row;
			justify-content: space-between;

			.paint-wear {
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				padding: 20rpx 0;

				.label {
					color: $app-text-thirdly;
					font-size: $font-size-md;
					margin-bottom: 10rpx;
				}
			}

			.item-sticker-list {
				padding-right: 30rpx;
			}
		}

		.item-price {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: flex-start;
