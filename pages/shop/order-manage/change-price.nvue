				background-color: $app-surface-elevated;
			}
		}
	}

	.up-shop-footer {
		width: 750rpx;
		height: 80rpx;
		position: fixed;
		bottom: 0rpx;
		left: 0;
		background-color: $app-background;
		border-top: 1rpx solid $app-surface;
		display: flex;
		flex-direction: row;
		justify-content: space-between;

		.left {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: flex-start;
			padding-left: 20rpx;

			.text {
				font-size: $font-size-sml;
				color: $app-text-primary;
			}

			.value {
				font-size: $font-size-sml;
